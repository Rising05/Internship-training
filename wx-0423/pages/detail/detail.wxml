<view class="detail-page">
  <xc-navbar
    title="商品详情"
    showBack
    rightText="{{product && product.isOwner ? '管理' : ''}}"
    bind:back="handleBack"
    bind:righttap="handleRightTap"
  />

  <view wx:if="{{loading}}" class="page-loading">正在加载商品详情...</view>

  <view wx:elif="{{errorMessage}}" class="page-shell">
    <view class="section-block detail-error-block">
      <text class="detail-error-title">商品详情加载失败</text>
      <text class="detail-error-copy">{{errorMessage}}</text>
      <button class="detail-retry-button" bindtap="handleRetry">重新加载</button>
    </view>
  </view>

  <block wx:elif="{{product}}">
    <view class="gallery-wrap">
      <swiper class="gallery" circular indicator-dots current="{{currentImageIndex}}" bindchange="handleSwiperChange">
        <swiper-item wx:for="{{displayImages}}" wx:key="index">
          <image class="gallery-image" src="{{item}}" mode="aspectFill" data-url="{{item}}" data-index="{{index}}" bindtap="handlePreview" binderror="handleGalleryImageError"></image>
        </swiper-item>
      </swiper>
      <view class="gallery-count">{{currentImageIndex + 1}}/{{displayImages.length}}</view>
    </view>

    <view class="page-shell">
      <view class="section-block">
        <view class="detail-status-row">
          <text class="detail-status detail-status-{{product.statusTone}}">{{product.statusLabel}}</text>
          <text class="detail-status-copy">{{product.statusDescription}}</text>
        </view>
        <view class="detail-price-row">
          <view>
            <text class="detail-price">¥{{product.price}}</text>
            <text class="detail-shipping">运费 ¥{{product.shippingFee}}</text>
          </view>
          <text class="pill-tag">{{product.tradeType}}</text>
        </view>
        <view class="detail-title">{{product.title}}</view>
        <view class="detail-meta">
          <text>{{product.idolDisplayName || product.idol}}</text>
          <text>{{product.condition}}</text>
          <text>库存 {{product.quantity}}</text>
          <text>{{product.category}}</text>
        </view>
        <view class="detail-tags">
          <text wx:for="{{product.tags}}" wx:key="*this" class="detail-tag">{{item}}</text>
        </view>
      </view>

      <view class="section-block seller-block">
        <view class="seller-avatar">{{product.seller.avatarText}}</view>
        <view class="seller-copy">
          <text class="seller-name">{{product.seller.name}}</text>
          <text class="seller-meta">{{product.seller.city}} · {{product.seller.level}} · 响应率 {{product.seller.responseRate}}</text>
          <text class="seller-intro">{{product.seller.intro}}</text>
        </view>
      </view>

      <view class="section-block seller-stats-block">
        <view class="seller-stat-item">
          <text class="seller-stat-value">{{product.seller.publishedCount}}</text>
          <text class="seller-stat-label">在架商品</text>
        </view>
        <view class="seller-stat-item">
          <text class="seller-stat-value">{{product.seller.responseRate}}</text>
          <text class="seller-stat-label">响应率</text>
        </view>
        <view class="seller-stat-item">
          <text class="seller-stat-value">{{product.quantity}}</text>
          <text class="seller-stat-label">库存</text>
        </view>
      </view>

      <view class="section-block">
        <view class="section-head">
          <text class="section-title">商品描述</text>
          <text class="section-subtitle">正式交易前建议先沟通细节</text>
        </view>
        <view class="detail-note">{{product.note || '卖家暂未补充更多说明，可先发起聊天了解细节。'}}</view>
      </view>

      <view class="section-block">
        <view class="section-head">
          <text class="section-title">平台说明</text>
          <text class="section-subtitle">已按正式版流程预留能力位</text>
        </view>
        <view wx:for="{{product.policies}}" wx:key="*this" class="policy-item">{{item}}</view>
      </view>

      <view wx:if="{{product.relatedProducts.length}}" class="section-block">
        <view class="section-head">
          <text class="section-title">相关推荐</text>
          <text class="section-subtitle">同担名或同分类的商品会优先展示</text>
        </view>
        <view class="related-grid">
          <product-card
            wx:for="{{product.relatedProducts}}"
            wx:key="id"
            product="{{item}}"
            bind:open="handleOpenRelated"
            bind:favorite="handleFavoriteRelated"
          />
        </view>
      </view>
    </view>

    <view class="bottom-bar">
      <view class="bottom-favorite {{product.isFavorite ? 'bottom-favorite-active' : ''}}" bindtap="handleFavorite">
        <image
          class="bottom-favorite-icon"
          src="{{product.isFavorite ? '/static/image/cropped/heart-active.png' : '/static/image/cropped/heart-default.png'}}"
          mode="aspectFit"
        />
        <text class="favorite-label">{{product.isFavorite ? '已收藏' : '收藏'}}</text>
      </view>
      <button class="bottom-button ghost" bindtap="handleContact">{{product.isOwner ? '查看会话' : '聊天'}}</button>
      <button wx:if="{{!product.isOwner}}" class="bottom-button primary" bindtap="handleConsult">{{product.canPurchase ? '立即求购' : product.statusLabel}}</button>
      <button wx:else class="bottom-button primary" loading="{{actionLoading}}" bindtap="handleRightTap">管理商品</button>
    </view>
  </block>

  <empty-state
    wx:else
    title="商品不存在"
    description="该商品可能已经下架，你可以返回首页继续浏览。"
  />
</view>
