page {
  min-height: 100%;
  background: linear-gradient(180deg, #fff8fb 0%, #fff3f7 100%);
  color: #43303a;
  font-size: 28rpx;
  --xc-primary: #ff5d97;
  --xc-primary-soft: #fff1f6;
  --xc-primary-deep: #ff84af;
  --xc-text: #3f2e38;
  --xc-subtle: #9e8a96;
  --xc-card: rgba(255, 255, 255, 0.92);
  --xc-shadow: 0 18rpx 40rpx rgba(255, 115, 156, 0.12);
}

view,
text,
button,
input,
textarea,
image,
scroll-view,
swiper,
swiper-item,
navigator {
  box-sizing: border-box;
}

.page-shell {
  padding: 24rpx 24rpx calc(154rpx + env(safe-area-inset-bottom));
}

.section-block {
  margin-top: 24rpx;
  padding: 28rpx;
  background: var(--xc-card);
  border-radius: 32rpx;
  box-shadow: var(--xc-shadow);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--xc-text);
}

.title-with-icon {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-icon {
  width: 30rpx;
  height: 30rpx;
  flex-shrink: 0;
}

.section-subtitle {
  font-size: 22rpx;
  color: var(--xc-subtle);
}

.pill-tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  background: #fff1f6;
  color: var(--xc-primary);
  font-size: 22rpx;
}

.ghost-button {
  border-radius: 999rpx;
  border: 2rpx solid #ffd1dc;
  background: #ffffff;
  color: var(--xc-primary);
  font-size: 24rpx;
}

.primary-button {
  border-radius: 999rpx;
  background: linear-gradient(135deg, var(--xc-primary-deep), var(--xc-primary));
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.soft-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 10rpx 24rpx rgba(255, 115, 156, 0.08);
}

.page-loading {
  padding: 120rpx 24rpx;
  text-align: center;
  color: var(--xc-subtle);
}

@import "./app-wxa-auto-dark.wxss";
