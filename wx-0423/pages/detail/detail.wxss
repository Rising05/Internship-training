.detail-page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.gallery-wrap {
  position: relative;
  margin: 0 24rpx;
}

.gallery {
  height: 620rpx;
  border-radius: 34rpx;
  overflow: hidden;
}

.gallery-image {
  width: 100%;
  height: 100%;
}

.gallery-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(45, 31, 39, 0.58);
  color: #ffffff;
  font-size: 22rpx;
}

.detail-price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.detail-status-row {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.detail-status {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: fit-content;
  min-width: 120rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-status-active {
  background: #eef9f0;
  color: #2f8f4f;
}

.detail-status-reserved {
  background: #fff5db;
  color: #b97b00;
}

.detail-status-sold {
  background: #f0eff8;
  color: #6e63a8;
}

.detail-status-hidden {
  background: #f6edf2;
  color: #9b8794;
}

.detail-status-copy {
  color: #8f7f88;
  line-height: 1.6;
}

.detail-price {
  color: #ff5d97;
  font-size: 48rpx;
  font-weight: 700;
}

.detail-shipping {
  margin-left: 14rpx;
  color: #8f7f88;
  font-size: 24rpx;
}

.detail-title {
  margin-top: 18rpx;
  color: #392833;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.6;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
  color: #9a8792;
  font-size: 24rpx;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.detail-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #fff2f7;
  color: #ff5d97;
  font-size: 22rpx;
}

.seller-block {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.seller-stats-block {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.seller-stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 18rpx 12rpx;
  border-radius: 24rpx;
  background: #fff5f9;
}

.seller-stat-value {
  color: #3d2b36;
  font-size: 30rpx;
  font-weight: 700;
}

.seller-stat-label {
  color: #9a8792;
  font-size: 22rpx;
}

.seller-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffc7da, #ff8cb3);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.seller-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.seller-name {
  color: #3d2b36;
  font-size: 30rpx;
  font-weight: 700;
}

.seller-meta,
.seller-intro,
.detail-note {
  color: #8f7f88;
  line-height: 1.7;
}

.policy-item {
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #fff5f9;
  color: #7a6370;
}

.related-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.detail-error-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  text-align: center;
}

.detail-error-title {
  color: #3d2b36;
  font-size: 32rpx;
  font-weight: 700;
}

.detail-error-copy {
  color: #8f7f88;
  line-height: 1.7;
}

.detail-retry-button {
  min-width: 240rpx;
  height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 700;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -10rpx 26rpx rgba(255, 111, 145, 0.1);
}

.bottom-favorite {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  min-width: 156rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: #fff2f7;
  color: #ff5d97;
}

.bottom-favorite-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
}

.bottom-favorite-icon {
  width: 26rpx;
  height: 26rpx;
  flex-shrink: 0;
}

.favorite-label {
  font-size: 24rpx;
  font-weight: 700;
}

.bottom-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 84rpx;
  padding: 0;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.bottom-button.ghost {
  background: #fff2f7;
  color: #ff5d97;
}

.bottom-button.primary {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
}
