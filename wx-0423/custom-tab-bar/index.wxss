.custom-tab-shell {
  position: relative;
  height: 126rpx;
}

.custom-tab-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 20rpx;
  height: 102rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 18rpx 40rpx rgba(241, 111, 149, 0.18);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  height: 100%;
  color: #a58f9d;
  font-size: 22rpx;
}

.tab-item-active {
  color: #ff5d97;
}

.tab-icon-wrap {
  position: relative;
  width: 40rpx;
  height: 40rpx;
}

.tab-icon {
  width: 100%;
  height: 100%;
}

.tab-label {
  line-height: 1;
  font-size: 22rpx;
}

.tab-badge {
  position: absolute;
  top: -8rpx;
  right: -18rpx;
  min-width: 28rpx;
  padding: 2rpx 8rpx;
  border-radius: 999rpx;
  background: #ff5d97;
  color: #ffffff;
  font-size: 18rpx;
  text-align: center;
}
