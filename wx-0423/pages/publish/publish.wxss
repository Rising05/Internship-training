.publish-page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.publish-hero {
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #ffe2ed, #ffd2e0);
  box-shadow: 0 18rpx 34rpx rgba(255, 116, 158, 0.12);
}

.hero-title {
  display: block;
  color: #3f2e38;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  color: #8d7884;
  line-height: 1.7;
}

.tip-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #755f6b;
  font-size: 22rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item,
.image-picker {
  position: relative;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.image-item {
  background: #f7dfe8;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(64, 42, 54, 0.72);
  color: #ffffff;
  text-align: center;
  line-height: 40rpx;
}

.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff3f8;
  color: #ff5d97;
}

.picker-plus {
  font-size: 42rpx;
  line-height: 1;
}

.picker-text {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.form-item {
  margin-top: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #6f5c67;
  font-size: 24rpx;
}

.double-row {
  display: flex;
  gap: 16rpx;
}

.half-item {
  flex: 1;
}

.form-input,
.picker-field,
.form-textarea {
  width: 100%;
  border-radius: 24rpx;
  background: #fff6fa;
  color: #3f2d38;
}

.form-input,
.picker-field {
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

.picker-trigger {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.picker-placeholder {
  color: #b9a6b0;
}

.picker-arrow {
  color: #b397a6;
  font-size: 30rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  line-height: 1.7;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.choice-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff3f8;
  color: #8c7884;
}

.choice-chip-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
}

.publish-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -10rpx 24rpx rgba(255, 111, 145, 0.08);
}

.publish-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  padding: 0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.selector-mask {
  position: fixed;
  inset: 0;
  background: rgba(47, 33, 40, 0.34);
  z-index: 998;
}

.selector-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 999;
  display: flex;
  flex-direction: column;
  height: 72vh;
  padding: 18rpx 24rpx calc(28rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #fffafc;
  box-shadow: 0 -18rpx 34rpx rgba(255, 111, 145, 0.12);
}

.selector-sheet-expanded {
  height: 90vh;
}

.selector-sheet-handle-zone {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-bottom: 10rpx;
  flex-shrink: 0;
}

.selector-sheet-handle {
  width: 84rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: #f0d8e3;
}

.selector-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.selector-sheet-title {
  color: #3f2e38;
  font-size: 30rpx;
  font-weight: 700;
}

.selector-sheet-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #fff1f6;
  color: #9a8893;
  text-align: center;
  line-height: 52rpx;
  font-size: 32rpx;
}

.selector-search-wrap {
  margin-top: 20rpx;
}

.selector-search-input {
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff3f8;
  font-size: 24rpx;
}

.selector-tab-row,
.selector-subtab-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.selector-tab,
.selector-subtab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #fff1f6;
  color: #9a8893;
  font-size: 22rpx;
}

.selector-tab-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  box-shadow: 0 10rpx 18rpx rgba(255, 93, 151, 0.18);
}

.selector-subtab-active,
.selector-chip-active {
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
  box-shadow: inset 0 0 0 2rpx #ff9bc0;
}

.selector-scroll {
  margin-top: 18rpx;
  flex: 1;
  min-height: 0;
}

.selector-section + .selector-section {
  margin-top: 24rpx;
}

.selector-section-title {
  display: block;
  margin-bottom: 14rpx;
  color: #8e7a85;
  font-size: 22rpx;
  font-weight: 700;
}

.selector-group-note {
  display: block;
  margin-bottom: 14rpx;
  color: #9c8894;
  font-size: 22rpx;
}

.selector-chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.selector-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff6fa;
  color: #8b7884;
  font-size: 24rpx;
}

.selector-chip-soft {
  background: #fff1f6;
}

.selector-actions {
  margin-top: 18rpx;
}

.selector-custom-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 24rpx;
  background: #fff3f8;
}

.selector-custom-input {
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 24rpx;
}

.selector-custom-submit {
  min-width: 92rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.selector-empty {
  padding: 72rpx 24rpx;
  text-align: center;
  color: #a28f99;
  font-size: 24rpx;
}
