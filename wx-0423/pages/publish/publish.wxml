<view class="publish-page">
  <xc-navbar title="发布商品" />

  <view wx:if="{{loading}}" class="page-loading">正在准备发布页...</view>

  <view wx:else class="page-shell">
    <view class="publish-hero">
      <text class="hero-title">发布出物</text>
      <text class="hero-desc">表单结构已按后端接入场景整理，后续只需替换真实 API 即可。</text>
      <view class="tip-list">
        <view wx:for="{{tips}}" wx:key="*this" class="tip-item">{{item}}</view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">上传图片</text>
        <text class="section-subtitle">最多 9 张，封面建议使用竖图</text>
      </view>
      <view class="image-grid">
        <view wx:for="{{imageList}}" wx:key="*this" class="image-item">
          <image class="preview-image" src="{{item}}" mode="aspectFill" data-url="{{item}}" bindtap="handlePreviewImage"></image>
          <view class="delete-badge" data-index="{{index}}" bindtap="handleDeleteImage">×</view>
        </view>
        <view wx:if="{{imageList.length < 9}}" class="image-picker" bindtap="handleChooseImage">
          <text class="picker-plus">+</text>
          <text class="picker-text">添加图片</text>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">基础信息</text>
        <text class="section-subtitle">标题、价格、数量和分类都已预留字段</text>
      </view>

      <view class="form-item">
        <text class="form-label">标题</text>
        <input class="form-input" placeholder="请输入商品标题" value="{{form.title}}" data-field="title" bindinput="handleTextInput" />
      </view>

      <view class="double-row">
        <view class="form-item half-item">
          <text class="form-label">价格</text>
          <input class="form-input" type="digit" placeholder="0.00" value="{{form.price}}" data-field="price" bindinput="handleTextInput" />
        </view>
        <view class="form-item half-item">
          <text class="form-label">数量</text>
          <input class="form-input" type="number" placeholder="1" value="{{form.quantity}}" data-field="quantity" bindinput="handleTextInput" />
        </view>
      </view>

      <view class="double-row">
        <view class="form-item half-item">
          <text class="form-label">担名</text>
          <view class="picker-field picker-trigger {{form.idolDisplayName ? '' : 'picker-placeholder'}}" data-mode="idol" bindtap="handleOpenSelector">
            <text>{{form.idolDisplayName || '请选择担名'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>
        <view class="form-item half-item">
          <text class="form-label">分类</text>
          <view class="picker-field picker-trigger {{form.category ? '' : 'picker-placeholder'}}" data-mode="category" bindtap="handleOpenSelector">
            <text>{{form.category || '请选择分类'}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">交易设置</text>
        <text class="section-subtitle">为真实发布接口预留成色、交易方式与运费字段</text>
      </view>

      <view class="form-item">
        <text class="form-label">交易方式</text>
        <view class="chip-row">
          <view
            wx:for="{{tradeTypeOptions}}"
            wx:key="*this"
            class="choice-chip {{form.tradeType === item ? 'choice-chip-active' : ''}}"
            data-value="{{item}}"
            bindtap="handleTradeTypeSelect"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">成色说明</text>
        <view class="chip-row">
          <view
            wx:for="{{conditionOptions}}"
            wx:key="*this"
            class="choice-chip {{form.condition === item ? 'choice-chip-active' : ''}}"
            data-value="{{item}}"
            bindtap="handleConditionSelect"
          >
            {{item}}
          </view>
        </view>
      </view>

      <view class="form-item">
        <text class="form-label">运费</text>
        <input class="form-input" type="digit" placeholder="包邮填 0" value="{{form.shippingFee}}" data-field="shippingFee" bindinput="handleTextInput" />
      </view>

      <view class="form-item">
        <text class="form-label">描述</text>
        <textarea class="form-textarea" placeholder="补充成色、包装、交换偏好等说明" value="{{form.note}}" data-field="note" bindinput="handleTextInput"></textarea>
      </view>
    </view>
  </view>

  <view wx:if="{{selectorVisible}}" class="selector-mask" bindtap="handleCloseSelector"></view>
  <view wx:if="{{selectorVisible}}" class="selector-sheet {{selectorExpanded ? 'selector-sheet-expanded' : ''}}" catchtap="noop">
    <view
      class="selector-sheet-handle-zone"
      bindtap="handleToggleSelectorExpand"
      catchtouchstart="handleSelectorTouchStart"
      catchtouchmove="handleSelectorTouchMove"
      catchtouchend="handleSelectorTouchEnd"
    >
      <view class="selector-sheet-handle"></view>
    </view>
    <view class="selector-sheet-head">
      <text class="selector-sheet-title">{{selectorTitle}}</text>
      <view class="selector-sheet-close" bindtap="handleCloseSelector">×</view>
    </view>

    <view class="selector-search-wrap">
      <input
        class="selector-search-input"
        placeholder="{{selectorMode === 'idol' ? '搜索担名' : '搜索分类'}}"
        value="{{selectorSearch}}"
        bindinput="handleSelectorSearchInput"
      />
    </view>

    <block wx:if="{{selectorMode === 'idol'}}">
      <view class="selector-tab-row">
        <view
          wx:for="{{idolTypeTabs}}"
          wx:key="key"
          class="selector-tab {{selectorTypeTab === item.key ? 'selector-tab-active' : ''}}"
          data-type="{{item.key}}"
          bindtap="handleSelectorTypeTabChange"
        >
          {{item.label}}
        </view>
      </view>
      <view class="selector-subtab-row">
        <view
          wx:for="{{idolRegionTabs}}"
          wx:key="key"
          class="selector-subtab {{selectorRegionTab === item.key ? 'selector-subtab-active' : ''}}"
          data-region="{{item.key}}"
          bindtap="handleSelectorRegionTabChange"
        >
          {{item.label}}
        </view>
      </view>
      <scroll-view scroll-y class="selector-scroll">
        <view class="selector-chip-grid">
          <view
            wx:for="{{selectorOptions}}"
            wx:key="*this"
            class="selector-chip {{selectorTypeTab === 'solo' ? (form.idolDisplayName === item ? 'selector-chip-active' : '') : (selectorGroupValue === item ? 'selector-chip-active' : '')}}"
            data-value="{{item}}"
            bindtap="handleSelectorOptionTap"
          >
            {{item}}
          </view>
        </view>
        <view wx:if="{{selectorTypeTab === 'group' && selectorGroupValue}}" class="selector-section">
          <text class="selector-section-title">成员选择</text>
          <text class="selector-group-note">已选团体：{{selectorGroupValue}}</text>
          <view class="selector-chip-grid">
            <view
              class="selector-chip {{selectorMemberValue ? '' : 'selector-chip-active'}}"
              data-value=""
              bindtap="handleSelectorMemberTap"
            >
              整团
            </view>
            <view
              wx:for="{{selectorMemberOptions}}"
              wx:key="*this"
              class="selector-chip {{selectorMemberValue === item ? 'selector-chip-active' : ''}}"
              data-value="{{item}}"
              bindtap="handleSelectorMemberTap"
            >
              {{item}}
            </view>
          </view>
        </view>
        <view class="selector-actions">
          <view
            class="selector-chip selector-chip-soft {{selectorCustomVisible && selectorCustomKind === 'group' ? 'selector-chip-active' : ''}}"
            data-kind="{{selectorTypeTab === 'solo' ? 'solo' : 'group'}}"
            bindtap="handleOpenSelectorCustom"
          >
            {{selectorTypeTab === 'solo' ? '其他担名' : '其他团体'}}
          </view>
          <view
            wx:if="{{selectorTypeTab === 'group' && selectorGroupValue}}"
            class="selector-chip selector-chip-soft {{selectorCustomVisible && selectorCustomKind === 'member' ? 'selector-chip-active' : ''}}"
            data-kind="member"
            bindtap="handleOpenSelectorCustom"
          >
            其他成员
          </view>
        </view>
        <view wx:if="{{selectorCustomVisible}}" class="selector-custom-box">
          <input
            class="selector-custom-input"
            placeholder="{{selectorCustomKind === 'member' ? '输入其他成员名' : (selectorCustomKind === 'group' ? '输入其他团体名' : '输入自定义担名')}}"
            value="{{selectorCustomValue}}"
            bindinput="handleSelectorCustomInput"
            bindconfirm="handleApplySelectorCustom"
            confirm-type="done"
          />
          <view class="selector-custom-submit" bindtap="handleApplySelectorCustom">确定</view>
        </view>
        <view wx:if="{{!selectorOptions.length && !selectorMemberOptions.length && !selectorCustomVisible}}" class="selector-empty">没有匹配到担名</view>
      </scroll-view>
    </block>

    <block wx:elif="{{selectorMode === 'category'}}">
      <scroll-view scroll-y class="selector-scroll">
        <view wx:if="{{selectorCommonOptions.length}}" class="selector-section">
          <text class="selector-section-title">常用分类</text>
          <view class="selector-chip-grid">
            <view
              wx:for="{{selectorCommonOptions}}"
              wx:key="*this"
              class="selector-chip {{form.category === item ? 'selector-chip-active' : ''}}"
              data-value="{{item}}"
              bindtap="handleSelectorOptionTap"
            >
              {{item}}
            </view>
          </view>
        </view>
        <view wx:if="{{selectorExtraOptions.length}}" class="selector-section">
          <text class="selector-section-title">{{selectorCommonOptions.length ? '更多分类' : '分类列表'}}</text>
          <view class="selector-chip-grid">
            <view
              wx:for="{{selectorExtraOptions}}"
              wx:key="*this"
              class="selector-chip {{form.category === item ? 'selector-chip-active' : ''}}"
              data-value="{{item}}"
              bindtap="handleSelectorOptionTap"
            >
              {{item}}
            </view>
          </view>
        </view>
        <view wx:if="{{!selectorCommonOptions.length && !selectorExtraOptions.length}}" class="selector-empty">没有匹配到分类</view>
      </scroll-view>
    </block>
  </view>

  <view class="publish-bottom-bar">
    <button class="publish-button" loading="{{submitting}}" bindtap="handleSubmit">发布商品</button>
  </view>
</view>
