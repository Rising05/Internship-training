.home-page {
  min-height: 100vh;
}

.hero-card {
  position: relative;
  overflow: hidden;
  height: 418rpx;
  border-radius: 36rpx;
  background: linear-gradient(135deg, #ff8fb7 0%, #ff6f91 45%, #ffb79e 100%);
  box-shadow: 0 20rpx 36rpx rgba(255, 111, 145, 0.14);
}

.hero-swiper,
.hero-slide,
.hero-cover-image,
.hero-fallback-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-swiper {
  z-index: 0;
}

.hero-slide {
  overflow: hidden;
}

.hero-cover-image {
  display: block;
}

.hero-banner-copy {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  bottom: 30rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  max-width: 360rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(12rpx);
}

.hero-banner-title {
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.hero-banner-subtitle {
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
  line-height: 1.6;
}

.hero-banner-cta {
  align-self: flex-start;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #ff5d97;
  font-size: 20rpx;
  font-weight: 700;
}

.hero-fallback-bg {
  z-index: 0;
  display: flex;
  align-items: flex-end;
  background:
    radial-gradient(circle at top right, rgba(255, 255, 255, 0.42), transparent 34%),
    linear-gradient(135deg, #ff8fb7 0%, #ff6f91 45%, #ffb79e 100%);
}

.hero-copy {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  max-width: 420rpx;
  padding: 34rpx;
}

.hero-eyebrow {
  color: rgba(255, 255, 255, 0.82);
  font-size: 22rpx;
  letter-spacing: 3rpx;
}

.hero-title {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 56rpx;
  font-weight: 700;
  line-height: 1.1;
}

.hero-subtitle {
  margin-top: 16rpx;
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.6;
}

.hero-announcement {
  margin-top: 16rpx;
  max-width: 440rpx;
  color: rgba(255, 255, 255, 0.8);
  font-size: 22rpx;
  line-height: 1.8;
}

.hero-dots {
  position: absolute;
  left: 50%;
  bottom: 18rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  backdrop-filter: blur(10rpx);
  transform: translateX(-50%);
}

.hero-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.56);
}

.hero-dot-active {
  width: 30rpx;
  border-radius: 999rpx;
  background: #ffffff;
}

.search-card {
  margin-top: 18rpx;
  padding: 20rpx 20rpx 18rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 14rpx 32rpx rgba(255, 111, 145, 0.08);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 8rpx;
  height: 92rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #fff3f8;
}

.search-icon {
  width: 34rpx;
  height: 34rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-submit {
  flex-shrink: 0;
  min-width: 96rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.search-suggestions {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.suggestions-label {
  color: #9b8794;
  font-size: 22rpx;
}

.suggestions-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.suggestion-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #fff6fa;
  color: #8f7b87;
  font-size: 22rpx;
}

.suggestion-chip-active {
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.quick-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #fff2f7;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.quick-item-active .quick-icon {
  background: linear-gradient(135deg, #fff6fa, #ffeef5);
  border-color: #ffc4da;
  box-shadow: 0 10rpx 18rpx rgba(255, 93, 151, 0.12);
  transform: translateY(-2rpx);
}

.quick-icon-image {
  width: 58rpx;
  height: 58rpx;
}

.quick-label {
  color: #7b6673;
  font-size: 24rpx;
}

.quick-item-active .quick-label {
  color: #ff5d97;
  font-weight: 700;
}

.quick-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
  margin-top: 20rpx;
  flex-wrap: wrap;
}

.section-action-pill {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
  font-size: 22rpx;
  font-weight: 600;
}

.section-action-pill-soft {
  background: #fff6fa;
  color: #a38b97;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.idol-filter-head {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.idol-filter-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.idol-type-switch {
  display: inline-flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #fff3f8;
  flex-shrink: 0;
}

.idol-type-tab {
  min-width: 88rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  color: #9a8893;
  font-size: 22rpx;
  text-align: center;
}

.idol-type-tab-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  box-shadow: 0 10rpx 18rpx rgba(255, 93, 151, 0.18);
}

.idol-region-switch {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  flex-wrap: wrap;
}

.idol-region-tab {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #fff6fa;
  color: #8f7f88;
  font-size: 22rpx;
}

.idol-region-tab-active {
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
  font-weight: 700;
}

.idol-group-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.idol-chip-wrap {
  margin-top: 18rpx;
}

.idol-chip-wrap-collapsed {
  max-height: 156rpx;
  overflow: hidden;
}

.idol-chip-grid {
  margin-top: 0;
}

.chip-action {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 18rpx rgba(255, 110, 153, 0.08);
}

.chip-action-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  box-shadow: 0 12rpx 20rpx rgba(255, 93, 151, 0.18);
}

.chip-action-soft {
  background: rgba(255, 255, 255, 0.85);
  color: #8f7f88;
}

.custom-idol-box {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
  padding: 16rpx;
  border-radius: 26rpx;
  background: #fff7fb;
}

.custom-idol-input {
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #ffffff;
  font-size: 24rpx;
}

.custom-idol-submit {
  min-width: 96rpx;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 24rpx;
  text-align: center;
}

.member-mask {
  position: fixed;
  inset: 0;
  background: rgba(47, 33, 40, 0.34);
  z-index: 1998;
}

.member-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1999;
  display: flex;
  flex-direction: column;
  height: 68vh;
  padding: 18rpx 24rpx calc(156rpx + env(safe-area-inset-bottom));
  border-radius: 36rpx 36rpx 0 0;
  background: #fffafc;
  box-shadow: 0 -18rpx 34rpx rgba(255, 111, 145, 0.12);
}

.member-sheet-handle {
  width: 84rpx;
  height: 8rpx;
  margin: 0 auto 16rpx;
  border-radius: 999rpx;
  background: #f0d8e3;
}

.member-sheet-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.member-sheet-title {
  display: block;
  color: #3f2e38;
  font-size: 30rpx;
  font-weight: 700;
}

.member-sheet-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #9b8794;
  font-size: 22rpx;
}

.member-sheet-close {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: #fff1f6;
  color: #9a8893;
  text-align: center;
  line-height: 52rpx;
  font-size: 32rpx;
  flex-shrink: 0;
}

.member-chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.member-sheet-scroll {
  flex: 1;
  min-height: 0;
  margin-top: 22rpx;
}

.member-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff6fa;
  color: #8b7884;
  font-size: 24rpx;
}

.member-chip-active {
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  color: #ff5d97;
  box-shadow: inset 0 0 0 2rpx #ff9bc0;
}

.member-sheet-actions {
  margin-top: 20rpx;
}

.member-custom-box {
  margin-top: 16rpx;
}

.feed-switch {
  display: inline-flex;
  padding: 8rpx;
  border-radius: 999rpx;
  background: #fff1f6;
}

.feed-tab {
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  color: #947f8b;
  font-size: 24rpx;
}

.feed-tab-active {
  background: #ffffff;
  color: #ff5d97;
  font-weight: 700;
  box-shadow: 0 8rpx 18rpx rgba(255, 93, 151, 0.14);
}

.waterfall {
  display: flex;
  gap: 20rpx;
  margin-top: 24rpx;
  align-items: flex-start;
}

.waterfall-column {
  flex: 1;
}

.load-tip {
  padding-top: 24rpx;
  text-align: center;
  color: #a08f99;
  font-size: 22rpx;
}
