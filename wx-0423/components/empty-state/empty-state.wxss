.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 56rpx 24rpx;
  text-align: center;
}

.empty-logo-image {
  width: 176rpx;
  height: 176rpx;
}

.empty-logo-text {
  color: #ff5d97;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
}

.empty-title {
  margin-top: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #45323b;
}

.empty-description {
  margin-top: 12rpx;
  color: #9f8d97;
  font-size: 24rpx;
  line-height: 1.6;
}

.empty-action {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 1;
}

@import "./empty-state-wxa-auto-dark.wxss";
