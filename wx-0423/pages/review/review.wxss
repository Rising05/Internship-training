.page-root {
  min-height: 100vh;
  background: #fff7fb;
}

.page-shell {
  padding: 24rpx;
}

.page-loading {
  padding: 120rpx 0;
  text-align: center;
  color: #8f7f88;
  font-size: 28rpx;
}

.stats-card,
.review-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 40rpx rgba(244, 140, 170, 0.1);
}

.stats-card {
  display: flex;
  gap: 16rpx;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  color: #ff5d97;
  font-size: 38rpx;
  font-weight: 700;
}

.stats-label {
  display: block;
  margin-top: 10rpx;
  color: #8f7f88;
  font-size: 22rpx;
}

.review-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.review-role,
.review-score {
  color: #2f2330;
  font-size: 26rpx;
  font-weight: 700;
}

.review-score {
  color: #ff5d97;
}

.review-author,
.review-product,
.review-time {
  display: block;
  margin-top: 12rpx;
  color: #8f7f88;
  font-size: 24rpx;
}

.review-content {
  display: block;
  margin-top: 16rpx;
  color: #5f4d57;
  font-size: 28rpx;
  line-height: 1.8;
}
