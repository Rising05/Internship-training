<view class="contain">
   <view class="title">普通选择器:</view>
   <picker bindchange="bindPikerChange" value="{{index}}" range="{{array}}">
    <view>
       当前选择:{{array[index]}}
    </view>
   </picker>
</view>
<!-- mode="time" 时间选择器模式 -->
<view class="contain">
   <view class="title">时间选择器:</view>
   <picker mode="time"  bindchange="bindTimeChange" value="{{time}}" start="09:01" end="21:01">
    <view>
       当前选择:{{time}}
    </view>
   </picker>
</view>
<!-- mode="date" 日期选择器模式 -->
<view class="contain">
   <view class="title">日期选择器:</view>
   <picker mode="date"  bindchange="bindDateChange" value="{{date}}" start="2000-01-01" end="2050-01-01">
    <view>
       当前选择:{{date}}
    </view>
   </picker>
</view>
<!-- mode="region" -->
<view class="contain">
   <view class="title">省市选择器:</view>
   <picker mode="region"  bindchange="bindRegionChange" value="{{region}}" start="2000-01-01" end="2050-01-01">
    <view>
       当前选择:{{region[0]}},{{region[1]}},{{region[2]}},
    </view>
   </picker>
</view>