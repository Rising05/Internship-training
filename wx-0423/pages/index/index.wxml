<view class="home-page">
  <xc-navbar title="星仓" />

  <view class="page-shell">
    <view class="hero-card">
      <swiper
        wx:if="{{banners.length && !bannerFallbackVisible}}"
        class="hero-swiper"
        circular
        autoplay
        interval="4200"
        duration="320"
        current="{{activeBannerIndex}}"
        bindchange="handleBannerChange"
      >
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <view class="hero-slide" data-index="{{index}}" bindtap="handleBannerTap">
            <image
              class="hero-cover-image"
              src="{{item.image}}"
              style="object-position: {{item.imagePosition}};"
              mode="aspectFill"
              binderror="handleBannerImageError"
            />
            <view class="hero-banner-copy">
              <text class="hero-banner-title">{{item.title}}</text>
              <text class="hero-banner-subtitle">{{item.subtitle}}</text>
              <text wx:if="{{item.ctaText}}" class="hero-banner-cta">{{item.ctaText}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
      <view wx:if="{{banners.length > 1 && !bannerFallbackVisible}}" class="hero-dots">
        <view
          wx:for="{{banners}}"
          wx:key="id"
          class="hero-dot {{activeBannerIndex === index ? 'hero-dot-active' : ''}}"
          data-index="{{index}}"
          catchtap="handleBannerDotTap"
        ></view>
      </view>
      <view wx:else class="hero-fallback-bg">
        <view class="hero-copy">
          <text class="hero-eyebrow">饭圈周边交易空间</text>
          <text class="hero-title">星仓</text>
          <text class="hero-subtitle">饭圈周边交易 · 买卖交换平台</text>
          <text class="hero-announcement">后续这里会切成可配置轮播广告位，支持活动图和专题入口。</text>
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="section-head">
        <text class="section-title">首页分类</text>
        <text class="section-subtitle">小卡、吧唧、应援物等快速筛选</text>
      </view>
      <view class="quick-grid">
        <view
          wx:for="{{visibleQuickEntries}}"
          wx:key="key"
          class="quick-item {{activeCategory === item.category ? 'quick-item-active' : ''}}"
          data-category="{{item.category}}"
          bindtap="handleQuickEntryTap"
        >
          <view class="quick-icon">
            <image class="quick-icon-image" src="{{item.iconPath}}" mode="aspectFit" />
          </view>
          <text class="quick-label">{{item.label}}</text>
        </view>
      </view>
      <view class="quick-actions">
        <view
          wx:if="{{hiddenQuickEntryCount > 0 && !isCategoryExpanded}}"
          class="section-action-pill"
          bindtap="handleToggleCategoryExpand"
        >
          更多分类
        </view>
        <view
          wx:if="{{isCategoryExpanded}}"
          class="section-action-pill section-action-pill-soft"
          bindtap="handleToggleCategoryExpand"
        >
          收起分类
        </view>
      </view>
    </view>

    <view class="section-block">
      <view class="idol-filter-head">
        <view class="idol-filter-title-row">
          <text class="section-title">担位筛选</text>
          <view class="idol-type-switch">
            <view
              wx:for="{{idolTypeTabs}}"
              wx:key="key"
              class="idol-type-tab {{idolTypeTab === item.key ? 'idol-type-tab-active' : ''}}"
              data-type="{{item.key}}"
              bindtap="handleIdolTypeTabChange"
            >
              {{item.label}}
            </view>
          </view>
        </view>
        <text class="section-subtitle">按担名快速定位商品</text>
      </view>

      <view class="idol-region-switch">
        <view
          wx:for="{{idolRegionTabs}}"
          wx:key="key"
          class="idol-region-tab {{idolRegionTab === item.key ? 'idol-region-tab-active' : ''}}"
          data-region="{{item.key}}"
          bindtap="handleIdolRegionTabChange"
        >
          {{item.label}}
        </view>
      </view>

      <view class="idol-chip-wrap {{!isIdolListExpanded && canExpandIdolList ? 'idol-chip-wrap-collapsed' : ''}}">
        <view class="chip-grid idol-chip-grid">
          <filter-chip
            wx:for="{{visibleIdolOptions}}"
            wx:key="*this"
            label="{{item}}"
            value="{{item}}"
            active="{{currentIdolSelection === item}}"
            bind:select="handleIdolSelect"
          />
        </view>
      </view>

      <view class="idol-group-actions">
        <view
          wx:if="{{idolTypeTab === 'group' && activeGroup !== '全部'}}"
          class="chip-action chip-action-soft"
          bindtap="handleOpenMemberSelector"
        >
          {{memberButtonText}}
        </view>
        <filter-chip
          wx:if="{{canExpandIdolList && !isIdolListExpanded}}"
          label="更多"
          value="more"
          bind:select="handleToggleIdolListExpand"
        />
        <filter-chip
          wx:if="{{canExpandIdolList && isIdolListExpanded}}"
          label="收起"
          value="less"
          bind:select="handleToggleIdolListExpand"
        />
        <view
          class="chip-action {{showCustomIdolInput ? 'chip-action-active' : ''}}"
          bindtap="handleOpenCustomIdol"
        >
          其他
        </view>
      </view>
      <view wx:if="{{showCustomIdolInput}}" class="custom-idol-box">
        <input
          class="custom-idol-input"
          placeholder="输入你的担名"
          value="{{customIdolDraft}}"
          bindinput="handleCustomIdolInput"
          bindconfirm="handleApplyCustomIdol"
          confirm-type="done"
        />
        <view class="custom-idol-submit" bindtap="handleApplyCustomIdol">确定</view>
      </view>
    </view>

    <view wx:if="{{memberSelectorVisible}}" class="member-mask" bindtap="handleCloseMemberSelector"></view>
    <view wx:if="{{memberSelectorVisible}}" class="member-sheet">
      <view class="member-sheet-handle"></view>
      <view class="member-sheet-head">
        <view>
          <text class="member-sheet-title">选择成员</text>
          <text class="member-sheet-subtitle">{{activeGroup}} 成员筛选</text>
        </view>
        <view class="member-sheet-close" bindtap="handleCloseMemberSelector">×</view>
      </view>
      <scroll-view scroll-y class="member-sheet-scroll">
        <view class="member-chip-grid">
          <view
            class="member-chip {{activeMember === '全部' ? 'member-chip-active' : ''}}"
            data-member="全部"
            bindtap="handleSelectMember"
          >
            整团
          </view>
          <view
            wx:for="{{memberSelectorOptions}}"
            wx:key="*this"
            class="member-chip {{activeMember === item ? 'member-chip-active' : ''}}"
            data-member="{{item}}"
            bindtap="handleSelectMember"
          >
            {{item}}
          </view>
        </view>
        <view class="member-sheet-actions">
          <view
            class="chip-action {{showCustomMemberInput ? 'chip-action-active' : ''}}"
            bindtap="handleOpenCustomMember"
          >
            其他成员
          </view>
        </view>
        <view wx:if="{{showCustomMemberInput}}" class="custom-idol-box member-custom-box">
          <input
            class="custom-idol-input"
            placeholder="输入成员名"
            value="{{customMemberDraft}}"
            bindinput="handleCustomMemberInput"
            bindconfirm="handleApplyCustomMember"
            confirm-type="done"
          />
          <view class="custom-idol-submit" bindtap="handleApplyCustomMember">确定</view>
        </view>
      </scroll-view>
    </view>

    <view class="search-card">
      <view class="search-input-wrap">
        <image class="search-icon" src="/static/image/icon-search.svg" mode="aspectFit" />
        <input
          class="search-input"
          placeholder="搜索商品、用户、关键词"
          value="{{draftKeyword}}"
          bindinput="handleSearchInput"
          bindconfirm="handleSubmitSearch"
          confirm-type="search"
        />
        <view class="search-submit" bindtap="handleSubmitSearch">搜索</view>
      </view>
      <view class="search-suggestions">
        <text class="suggestions-label">相关搜索</text>
        <view class="suggestions-row">
          <view
            wx:for="{{searchSuggestions}}"
            wx:key="*this"
            class="suggestion-chip {{draftKeyword === item ? 'suggestion-chip-active' : ''}}"
            data-keyword="{{item}}"
            bindtap="handleSuggestionTap"
          >
            {{item}}
          </view>
        </view>
      </view>
    </view>

    <view id="feed-section" class="section-block">
      <view class="section-head">
        <text class="section-title">推荐商品</text>
        <text class="section-subtitle">保留 mock 数据结构，后续可直接切真实接口</text>
      </view>
      <view class="feed-switch">
        <view
          wx:for="{{feedModes}}"
          wx:key="key"
          class="feed-tab {{activeFeed === item.key ? 'feed-tab-active' : ''}}"
          data-feed="{{item.key}}"
          bindtap="handleFeedSwitch"
        >
          {{item.label}}
        </view>
      </view>

      <view class="feed-result-card">
        <view class="feed-result-main">
          <text class="feed-result-count">{{resultSummaryText}}</text>
          <text class="feed-result-hint">{{resultSummaryHint}}</text>
        </view>
        <view
          wx:if="{{hasActiveFilters}}"
          class="feed-result-reset"
          bindtap="handleResetFilters"
        >
          重置筛选
        </view>
      </view>
      <view wx:if="{{hasActiveFilters}}" class="feed-result-tags">
        <text wx:for="{{filterSummaryTags}}" wx:key="*this" class="feed-result-tag">{{item}}</text>
      </view>

      <view wx:if="{{loading}}" class="page-loading">正在加载首页内容...</view>
      <block wx:elif="{{leftColumn.length + rightColumn.length}}">
        <view class="waterfall">
          <view class="waterfall-column">
            <product-card
              wx:for="{{leftColumn}}"
              wx:key="id"
              product="{{item}}"
              bind:favorite="handleFavorite"
              bind:open="handleOpenProduct"
            />
          </view>
          <view class="waterfall-column">
            <product-card
              wx:for="{{rightColumn}}"
              wx:key="id"
              product="{{item}}"
              bind:favorite="handleFavorite"
              bind:open="handleOpenProduct"
            />
          </view>
        </view>
        <view class="load-tip">{{loadingMore ? '正在加载更多商品...' : (hasMore ? '上拉查看更多商品' : '已经到底了，试试发布自己的商品吧')}}</view>
      </block>
      <empty-state
        wx:else
        title="没有找到匹配商品"
        description="{{emptyStateDescription}}"
        action-text="恢复默认筛选"
        bind:action="handleResetFilters"
      />
    </view>
  </view>
</view>
