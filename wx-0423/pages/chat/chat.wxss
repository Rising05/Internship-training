.chat-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fff8fb 0%, #fff1f6 100%);
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.chat-loading {
  padding: 80rpx 24rpx;
  text-align: center;
  color: #9d8897;
}

.chat-header {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 14rpx 32rpx rgba(255, 115, 156, 0.08);
}

.chat-user-avatar,
.chat-bubble-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb0c9, #ff77a6);
  color: #ffffff;
  flex-shrink: 0;
}

.chat-user-avatar {
  width: 84rpx;
  height: 84rpx;
  font-size: 30rpx;
  font-weight: 700;
}

.chat-bubble-avatar {
  width: 64rpx;
  height: 64rpx;
  font-size: 24rpx;
}

.chat-user-copy {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chat-user-name {
  color: #3c2935;
  font-size: 30rpx;
  font-weight: 700;
}

.chat-user-subtitle {
  color: #9c8895;
  font-size: 22rpx;
}

.chat-product-card {
  display: flex;
  gap: 18rpx;
  align-items: center;
  margin: 18rpx 24rpx 0;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.92);
}

.chat-product-cover,
.bubble-product-cover {
  border-radius: 20rpx;
  background: #f7dfe8;
}

.chat-product-cover {
  width: 112rpx;
  height: 112rpx;
}

.chat-product-copy,
.bubble-product-copy {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  min-width: 0;
}

.chat-product-title,
.bubble-product-title {
  color: #3d2b36;
  font-weight: 700;
  line-height: 1.5;
}

.chat-product-price,
.bubble-product-price {
  color: #ff5d97;
  font-weight: 700;
}

.chat-scroll {
  height: calc(100vh - 420rpx);
  padding: 20rpx 24rpx;
}

.chat-row {
  display: flex;
  gap: 16rpx;
  align-items: flex-end;
  margin-top: 18rpx;
}

.chat-row-self {
  justify-content: flex-end;
}

.chat-bubble {
  max-width: 520rpx;
  padding: 22rpx 24rpx 16rpx;
  border-radius: 28rpx 28rpx 28rpx 12rpx;
  background: rgba(255, 255, 255, 0.94);
  color: #41303a;
  box-shadow: 0 10rpx 24rpx rgba(255, 115, 156, 0.08);
}

.chat-bubble-self {
  border-radius: 28rpx 28rpx 12rpx 28rpx;
  background: linear-gradient(135deg, #ffd4e3, #ffc3da);
}

.chat-text {
  line-height: 1.7;
}

.chat-time {
  display: block;
  margin-top: 12rpx;
  color: #b19daa;
  font-size: 20rpx;
}

.bubble-product {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.bubble-product-cover {
  width: 100rpx;
  height: 100rpx;
}

.chat-input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 -10rpx 24rpx rgba(255, 115, 156, 0.08);
}

.chat-input {
  flex: 1;
  height: 84rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: #fff4f8;
}

.chat-send {
  width: 152rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff88b4, #ff5d97);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
}
