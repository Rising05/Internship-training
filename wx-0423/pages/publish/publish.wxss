.publish-page {
  min-height: 100vh;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.publish-hero {
  padding: 30rpx;
  border-radius: 34rpx;
  background: linear-gradient(135deg, #ffe2ed, #ffd2e0);
  box-shadow: 0 18rpx 34rpx rgba(255, 116, 158, 0.12);
}

.hero-title {
  display: block;
  color: #3f2e38;
  font-size: 36rpx;
  font-weight: 700;
}

.hero-desc {
  display: block;
  margin-top: 10rpx;
  color: #8d7884;
  line-height: 1.7;
}

.tip-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.tip-item {
  padding: 16rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #755f6b;
  font-size: 22rpx;
}

.type-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
}

.type-item {
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  background: #fff6fa;
  text-align: center;
}

.type-item-active {
  background: linear-gradient(135deg, #ffedf4, #ffdbe8);
  box-shadow: inset 0 0 0 2rpx #ff8db8;
}

.type-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 72rpx;
  height: 72rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #ffffff;
}

.type-icon-image {
  width: 48rpx;
  height: 48rpx;
}

.type-label {
  display: block;
  margin-top: 10rpx;
  color: #7d6874;
  font-size: 22rpx;
}

.image-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.image-item,
.image-picker {
  position: relative;
  height: 200rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.image-item {
  background: #f7dfe8;
}

.preview-image {
  width: 100%;
  height: 100%;
}

.delete-badge {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(64, 42, 54, 0.72);
  color: #ffffff;
  text-align: center;
  line-height: 40rpx;
}

.image-picker {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff3f8;
  color: #ff5d97;
}

.picker-plus {
  font-size: 42rpx;
  line-height: 1;
}

.picker-text {
  margin-top: 8rpx;
  font-size: 22rpx;
}

.form-item {
  margin-top: 20rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #6f5c67;
  font-size: 24rpx;
}

.double-row {
  display: flex;
  gap: 16rpx;
}

.half-item {
  flex: 1;
}

.form-input,
.picker-field,
.form-textarea {
  width: 100%;
  border-radius: 24rpx;
  background: #fff6fa;
  color: #3f2d38;
}

.form-input,
.picker-field {
  height: 88rpx;
  padding: 0 24rpx;
  line-height: 88rpx;
}

.form-textarea {
  min-height: 220rpx;
  padding: 24rpx;
  line-height: 1.7;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.choice-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: #fff3f8;
  color: #8c7884;
}

.choice-chip-active {
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
}

.publish-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 -10rpx 24rpx rgba(255, 111, 145, 0.08);
}

.publish-button {
  width: 100%;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff84af, #ff5d97);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}
