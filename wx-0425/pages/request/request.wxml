<view>
<!-- 轮播图 -->
<swiper indicator-dots="{{indicatorDots}}"
        autoplay="{{autoplay}}" interval="{{interval}}" duration="{{duration}}" circular style="height: 200px;">
        <block wx:for="{{swipers}}" wx:key="index">
          <swiper-item class="item">
            <view>
              <navigator open-type="reLaunch" url="{{item.navigator_url}}">
                <image src="{{item.image_src}}" style="width:100%;height: 200px;" mode="aspectFill" lazy-load></image>
              </navigator>
            </view>
          </swiper-item>
        </block>
</swiper>
<!-- 商品列表 -->
   <!-- <view wx:for="{{goodsList}}" wx:key="index">
       <view>{{item.goods_name}}</view>
       <image src="{{item.goods_small_logo}}" mode="aspectFill"  lazy-load></image>
   </view> -->
   <scroll-view scroll-y="true" style="height:450px">
      <view class="lists">
        <view wx:for="{{goodsList}}" wx:key="index" class="item">
          <navigator url="/pages/detail/detail?id={{item.goods_id}}">
            <image src="{{item.goods_small_logo}}" class="img" mode="aspectFill"  lazy-load></image>
          </navigator>
          <view class="info">
            <view class="title">{{item.goods_name}}</view>
            <view class="price">{{item.goods_price}}</view>
          </view>
        </view>
      </view>
   </scroll-view>
</view>